# Upstream auth
ARK_API_KEY=your-ark-api-key
CLIPROXY_KEY=your-cliproxy-key

# Hub auth tokens
HUB_KIMI_AUTH=your-kimi-token
HUB_DEEPSEEK_AUTH=your-deepseek-token
HUB_GLM_AUTH=your-glm-token
HUB_DOUBAO_AUTH=your-doubao-token
HUB_MINIMAX_AUTH=your-minimax-token
HUB_METASO_AUTH=your-metaso-token
HUB_QWEN_AUTH=your-qwen-token
HUB_YUANBAO_AUTH=your-yuanbao-token

# Hub base URLs (optional, defaults to localhost)
# HUB_KIMI_BASE=http://your-hub-host:8010
# HUB_DEEPSEEK_BASE=http://your-hub-host:8011
# HUB_GLM_BASE=http://your-hub-host:8013
# HUB_DOUBAO_BASE=http://your-hub-host:8014
# HUB_MINIMAX_BASE=http://your-hub-host:8017
# HUB_METASO_BASE=http://your-hub-host:8019
# HUB_QWEN_BASE=http://your-hub-host:8012
# HUB_YUANBAO_BASE=http://your-hub-host:8015
# HUB_GEMINI_BASE=http://your-hub-host:8020

# Deploy target (optional)
# DEPLOY_TARGET=root@your-server-ip
